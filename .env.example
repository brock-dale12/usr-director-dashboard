# USR Director Dashboard — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real keys.
#
# Local dev uses ONE .env at the app root: `netlify dev` injects ALL of these
# into Functions, while Vite exposes ONLY the VITE_-prefixed vars to the browser
# bundle. In production, the SERVER vars below are set in the Netlify dashboard
# (Site settings → Environment), NOT in this file.

# ───────────────────────────────────────────────────────────────────
# FRONTEND (safe in the browser bundle — must be VITE_-prefixed)
# ───────────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API)
VITE_SUPABASE_URL=https://hasuuffsaruzqgklbddt.supabase.co

# Supabase anon/public key (Settings → API → "anon public")
# SAFE in the frontend — RLS policies protect the data.
# Do NOT use the service_role key here.
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key_here

# ───────────────────────────────────────────────────────────────────
# SERVER — Functions only. SECRETS. Never VITE_-prefixed, never in the
# bundle. In production these live in Netlify env, not in a committed file.
# ───────────────────────────────────────────────────────────────────

# Supabase service_role key (Settings → API → "service_role"). Full DB access.
# Functions use this to mirror write-throughs back into Supabase.
SUPABASE_SERVICE_KEY=

# HubSpot private-app token (starts with pat-). Read today; add write scopes in Phase 2.
HUBSPOT_ACCESS_TOKEN=

# ── Gmail "send from dashboard" (Option B) ──────────────────────────
# OAuth client (Google Cloud Console -> APIs & Services -> Credentials ->
# OAuth client ID -> "Web application"). See gmail-send-SETUP.md for full steps.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# The redirect URI registered on that OAuth client. MUST match exactly.
#   prod:  https://<your-netlify-domain>/.netlify/functions/gmail-oauth-callback
#   local: http://localhost:8888/.netlify/functions/gmail-oauth-callback
GOOGLE_OAUTH_REDIRECT_URI=

# Where the callback sends the CSM back to (your app origin, no trailing slash).
#   prod:  https://<your-netlify-domain>     local: http://localhost:8888
APP_URL=

# 32-byte key for AES-256-GCM encryption of stored refresh tokens.
# Generate:  openssl rand -hex 32   (64 hex chars) — or base64 of 32 bytes.
TOKEN_ENC_KEY=
